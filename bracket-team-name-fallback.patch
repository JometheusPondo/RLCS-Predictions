+func TestLooksLikePlaceholderTeamName(t *testing.T) {
+	placeholders := []string{
+		"",
+		"   ",
+		"#N/A",
+		"#REF!",
+		"#ERROR!",
+		"Winner of A",
+		"Winner of C",
+		"winner of g",
+		"WINNER OF B",
+		"Loser of A",
+		"Loser of B",
+		"Group A First",
+		"Group D Third",
+		"group b second",
+	}
+	realTeams := []string{
+		"Karmine Corp",
+		"Twisted Minds",
+		"FURIA",
+		"NRG",
+		"Team Vitality",
+		"Manchester City Esports",
+		"Spacestation Gaming",
+		"Ninjas in Pyjamas",
+		"FUT Esports",
+		"Made In Brazil",
+	}
+	for _, s := range placeholders {
+		if !looksLikePlaceholderTeamName(s) {
+			t.Errorf("expected %q to look like a placeholder", s)
+		}
+	}
+	for _, s := range realTeams {
+		if looksLikePlaceholderTeamName(s) {
+			t.Errorf("expected %q to NOT look like a placeholder", s)
+		}
+	}
+}
