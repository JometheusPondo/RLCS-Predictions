# Server
PORT=8080

# Database
DATABASE_PATH=./data/rlcs.db

# Match source — "liquipedia" (HTML scrape via MediaWiki API) or "sheet"
# (CSV export of two Google Sheets tabs). Default keeps existing installs
# on the original behavior. Switching mid-tournament orphans existing
# predictions (the two sources produce different match_id hashes), so
# pick at deploy time and stick with it.
MATCH_SOURCE=liquipedia

# Liquipedia — used when MATCH_SOURCE=liquipedia.
LIQUIPEDIA_PAGE=Rocket_League_Championship_Series/2026/Paris_Major
LIQUIPEDIA_POLL_INTERVAL=5m
# Set a real contact in the User-Agent before any sync against production. Liquipedia bans on missing/empty contact info.
LIQUIPEDIA_USER_AGENT=RLCSPredictions/0.1 (https://github.com/jometheus/rlcs-predictions; contact: replace-me@example.com)

# Google Sheets — used when MATCH_SOURCE=sheet. The spreadsheet must be
# shared "Anyone with the link can view" — no auth is performed. The
# three IDs together uniquely identify the spreadsheet and which two tabs
# carry the Groups Output and Bracket Output data. Defaults point at the
# 2026 Paris Major broadcast LOP; override all three together when
# pointing at a different tournament's sheet.
SHEET_SPREADSHEET_ID=1Eo3OEO8CY048BTz8QFmWG-xczH6UOecjFCFZCJQuLUs
SHEET_GROUPS_GID=10266191
SHEET_BRACKET_GID=936433744
SHEET_POLL_INTERVAL=2m

# Logging — debug | info | warn | error
LOG_LEVEL=info

# Dev mode — enables POST /api/sync/now for manual sync triggers. Off in prod.
DEV_MODE=false
