# Go binaries
bin/
*.exe

# SQLite databases
data/
*.db
*.db-shm
*.db-wal
*.db-journal

# Secrets / local env
.env

# Node / pnpm
node_modules/
.pnpm-store/

# Frontend build output (embedded into Go binary at build time). The dir
# itself must persist so //go:embed all:web/dist compiles before a build —
# keep .gitkeep, ignore everything else.
web/dist/*
!web/dist/.gitkeep

# Scraper dev artifacts
tmp/
last_response.html

# OS junk
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*~
