# Supply-chain hygiene per spec § 2.1.
# - enable-pre-post-scripts=false  blocks pre/post-install/prepare hooks on every package
#   in the tree as defense-in-depth against the Shai-Hulud class of attacks.
# - auto-install-peers=true        ergonomics; otherwise React 19 peer ranges become painful.
# - strict-peer-dependencies=true  fails loudly on peer mismatches rather than silently producing a broken graph.
enable-pre-post-scripts=false
auto-install-peers=true
strict-peer-dependencies=true
